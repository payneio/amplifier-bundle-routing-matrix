// simple-fix.dot
//
// Pipeline: Simple Fix (triage-driven)
//
// Triage has already analyzed the issue. This pipeline:
//   1. Read triage findings, write a brief design summary
//   2. Plan the fix at task level
//   3. Checkout a fix branch
//   4. Implement the fix (LLM handles TDD, tests, commits internally)
//   5. Validate (auto-detect test runner)
//   6. Push the branch + create a PR via the GitHub API
//   7. Comment draft posts results back and triggers /review-pr

digraph simple_fix {

    // — Graph-level attributes ————————————————————————————————————————

    label             = "Simple Fix"
    description       = "Implement a simple code fix from triage findings, create PR, trigger review"
    labelloc          = t
    rankdir           = TB
    compound          = true

    // Attractor pipeline configuration
    goal              = "$goal"
    default_fidelity  = "full"
    default_thread_id = "simple-fix-thread"

    // — Model stylesheet —————————————————————————————————————————————
    model_stylesheet  = "read_triage: model_role=general; plan_fix: model_role=reasoning; implement_fix: model_role=coding; validate_fix: model_role=coding; comment_draft: model_role=general"

    // — Default node and edge styles —————————————————————————————————
    node [fontname="Helvetica", fontsize=11, style="filled"]
    edge [fontname="Helvetica", fontsize=10, color="#555555"]

    // ════════════════════════════════════════════════════════════════
    // PIPELINE NODES
    // ════════════════════════════════════════════════════════════════

    // Entry point
    start [
        label     = "Start",
        shape     = Mdiamond,
        fillcolor = "#C8E6C9"
    ]

    // Read triage — extract root cause / files / suggested fix, write design summary
    read_triage [
        label     = "Read Triage",
        shape     = box,
        fillcolor = "#E8F0FE",
        prompt    = "You are reading triage findings. Read the issue and triage analysis from $goal.\n\nExtract:\n- ROOT CAUSE: What is broken and why\n- FILES TO CHANGE: Which files need changes\n- SUGGESTED FIX: The approach triage recommends\n\nWrite a brief design summary to docs/fix-design.md capturing the above. Then git add and git commit the file.\n\nOutput:\n{\"status\": \"success\", \"context_updates\": {\"fix_design\": \"docs/fix-design.md written\"}}"
    ]

    // Plan fix — concise task-level implementation plan
    plan_fix [
        label      = "Plan Fix",
        shape      = box,
        fillcolor  = "#E8F0FE",
        max_cycles = 2,
        prompt     = "You are a fix planner. Read the design summary from docs/fix-design.md.\n\nCreate a concise implementation plan at docs/fix-plan.md with:\n- FILES TO CHANGE: Exact files and the line-level changes in each\n- TESTS: Which tests to write or modify to verify the fix\n- VERIFICATION: Steps to confirm the fix works\n\nKeep the plan concise and actionable. Then git add and git commit the plan.\n\nOutput:\n{\"status\": \"success\", \"context_updates\": {\"fix_plan\": \"docs/fix-plan.md written\"}}"
    ]

    // Checkout branch — create and switch to a fix branch
    checkout_branch [
        label      = "Checkout Branch",
        shape      = parallelogram,
        fillcolor  = "#FFF9C4",
        tool_command = "bash -c 'BRANCH=\"resolve/fix-$(date +%Y%m%d-%H%M%S)\"; git checkout -b \"$BRANCH\"; echo \"$BRANCH\"'"
    ]

    // Implement fix — the LLM handles everything: write tests, write code,
    // run tests, fix failures, git add specific files, git commit.
    implement_fix [
        label      = "Implement Fix",
        shape      = box,
        fillcolor  = "#E8F0FE",
        max_cycles = 3,
        goal_gate  = true,
        fidelity   = "full",
        prompt     = "You are implementing a code fix.\n\nRead the fix plan from docs/fix-plan.md.\n\nProcess:\n1. Write a test that reproduces the bug\n2. Run the test to confirm it fails\n3. Write the minimal code to fix the issue\n4. Run tests to confirm the fix works and no regressions\n5. git add the changed files (specific files, not -A)\n6. git commit with a descriptive message\n\nIf tests fail, debug and fix. You have 3 attempts.\n\nOutput:\n{\"status\": \"success\", \"context_updates\": {\"implementation_summary\": \"YOUR SUMMARY: what files changed, what tests pass, what was fixed\"}}"
    ]

    // Validate fix — auto-detect the test runner and run it
    validate_fix [
        label      = "Validate Fix",
        shape      = parallelogram,
        fillcolor  = "#FFF9C4",
        tool_command = "#!/bin/sh\nif [ -f pyproject.toml ]; then\n  if command -v pytest >/dev/null 2>&1; then\n    pytest 2>&1 | tail -20\n  else\n    python -m pytest 2>&1 | tail -20\n  fi\nelif [ -f package.json ]; then\n  npm test 2>&1 | tail -20\nelif [ -f Cargo.toml ]; then\n  cargo test 2>&1 | tail -20\nelse\n  echo 'no recognized test config found; skipping validation'\nfi"
    ]

    // Push branch + create PR — push directly to GitHub using GH_TOKEN
    // (Gitea promotion has a known Incus/Docker runtime mismatch bug,
    //  so we bypass it and push to GitHub directly)
    push_and_pr [
        label      = "Push & PR",
        shape      = parallelogram,
        fillcolor  = "#FFF9C4",
        parse_json = true,
        tool_command = "#!/bin/sh\nset -e\nBRANCH=$(git rev-parse --abbrev-ref HEAD)\nREPO_URL=$(echo \"$goal\" | grep -oP 'https://github.com/[^/]+/[^/# ]+' | head -1)\nif [ -z \"$REPO_URL\" ]; then\n  printf '{\"error\": \"no repo URL found in goal\"}'\n  exit 1\nfi\nOWNER_REPO=$(echo \"$REPO_URL\" | sed 's|https://github.com/||')\ngit remote add github \"https://x-access-token:${GH_TOKEN}@github.com/${OWNER_REPO}.git\" 2>/dev/null || git remote set-url github \"https://x-access-token:${GH_TOKEN}@github.com/${OWNER_REPO}.git\"\ngit push -u github \"$BRANCH\" 2>&1\nPR_TITLE=$(head -1 docs/fix-design.md 2>/dev/null | sed 's/^#* *//' || echo \"Automated fix\")\nRESP=$(curl -s -X POST \\\n  -H \"Authorization: token ${GH_TOKEN}\" \\\n  -H \"Accept: application/vnd.github+json\" \\\n  \"https://api.github.com/repos/${OWNER_REPO}/pulls\" \\\n  -d \"{\\\"title\\\": \\\"${PR_TITLE}\\\", \\\"head\\\": \\\"${BRANCH}\\\", \\\"base\\\": \\\"main\\\", \\\"body\\\": \\\"Automated fix from triage findings. See docs/fix-design.md and docs/fix-plan.md for details.\\\"}\")\nPR_URL=$(echo \"$RESP\" | grep -o '\"html_url\": \"[^\"]*\"' | head -1 | cut -d'\"' -f4)\nPR_NUMBER=$(echo \"$RESP\" | grep -o '\"number\": *[0-9]*' | head -1 | grep -o '[0-9]*')\nif [ -n \"$PR_URL\" ]; then\n  printf '{\"delivery.pr_url\": \"%s\", \"delivery.pr_number\": \"%s\", \"delivery.owner_repo\": \"%s\"}' \"$PR_URL\" \"$PR_NUMBER\" \"$OWNER_REPO\"\nelse\n  printf '{\"delivery.pr_url\": \"\", \"delivery.pr_number\": \"\", \"delivery.owner_repo\": \"%s\", \"note\": \"push succeeded but PR creation failed\"}' \"$OWNER_REPO\"\nfi"
    ]

    // Comment draft — writes bridge.* output and triggers /review-pr
    comment_draft [
        label     = "Draft Comment",
        shape     = box,
        fillcolor = "#E8F0FE",
        prompt    = "Draft a GitHub issue comment summarizing the implemented fix.\n\nRead $implementation_summary for what was done.\nPR URL: $delivery.pr_url\nPR number: $delivery.pr_number\nOwner/repo: $delivery.owner_repo\n\nThe comment MUST include:\n- A brief summary of what was fixed and how\n- Which files were changed\n- A link to the PR: $delivery.pr_url\n- On a NEW LINE at the very end, this exact trigger so review runs automatically:\n/review-pr $delivery.owner_repo#$delivery.pr_number\n\nOutput:\n{\"status\": \"success\", \"context_updates\": {\"bridge.comment\": \"YOUR COMMENT IN MARKDOWN\", \"bridge.summary\": \"ONE-LINE FIX SUMMARY\", \"bridge.labels\": [\"fix-implemented\"]}}\n\nCRITICAL: Your ENTIRE response must be ONLY the JSON object above. No preamble, no explanation, no markdown code fences, no text before or after. Just the raw JSON."
    ]

    // Pipeline exit
    done [
        label     = "Done",
        shape     = Msquare,
        fillcolor = "#FFCDD2"
    ]

    // ════════════════════════════════════════════════════════════════
    // EDGES
    // ════════════════════════════════════════════════════════════════

    start -> read_triage
    read_triage -> plan_fix
    plan_fix -> checkout_branch
    checkout_branch -> implement_fix
    implement_fix -> validate_fix
    validate_fix -> push_and_pr
    push_and_pr -> comment_draft
    comment_draft -> done

}

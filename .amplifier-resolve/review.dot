// review.dot
//
// Pipeline: PR Code Review
//
// Simple flow:
//   1. Discover the PR (from goal text or latest open PR)
//   2. LLM reviews the code changes
//   3. Post results via bridge.* comment

digraph code_review {

    // — Graph-level attributes ————————————————————————————————————
    label             = "Code Review"
    description       = "Review a PR for code quality, correctness, and test coverage"
    labelloc          = t
    rankdir           = TB
    compound          = true

    // Attractor pipeline configuration
    goal              = "$goal"
    default_fidelity  = "full"
    default_thread_id = "code-review-thread"

    // — Model stylesheet ————————————————————————————————————————
    model_stylesheet  = "code_review: model_role=reasoning; comment_draft: model_role=general"

    // — Default styles ——————————————————————————————————————————
    node [fontname="Helvetica", fontsize=11, style="filled"]
    edge [fontname="Helvetica", fontsize=10, color="#555555"]

    // ═══════════════════════════════════════════════════════════
    // PIPELINE NODES
    // ═══════════════════════════════════════════════════════════

    start [
        label     = "Start",
        shape     = Mdiamond,
        fillcolor = "#C8E6C9"
    ]

    // Code review — the LLM reads the repo, finds the PR,
    // reviews the diff, and produces a structured review.
    // It has bash + git + curl + GH_TOKEN available.
    code_review [
        label      = "Code Review",
        shape      = box,
        fillcolor  = "#E8F0FE",
        fidelity   = "full",
        goal_gate  = true,
        prompt     = "You are an expert code reviewer.\n\nRead $goal to understand the context. Your job is to find and review the most recent PR or code changes in the workspace.\n\nStep 1 — Find the PR:\n- Look for PR references in $goal (e.g. PR #7, pull/7)\n- Or find the latest open PR: curl -s -H \"Authorization: token ${GH_TOKEN}\" \"https://api.github.com/repos/$(git remote get-url origin | grep -oP 'github.com[:/]\\K[^.]+' | head -1)/pulls?state=open&per_page=1\"\n- Get the diff: curl -s -H \"Authorization: token ${GH_TOKEN}\" -H \"Accept: application/vnd.github.diff\" \"https://api.github.com/repos/OWNER/REPO/pulls/NUMBER\"\n\nStep 2 — Review the diff across these dimensions:\n1. **Correctness**: Logic errors, edge cases, off-by-one mistakes\n2. **Code Quality**: Readability, naming, structure, conventions\n3. **Test Coverage**: Are changes tested? Edge cases covered?\n4. **Security**: Injection risks, credential leaks, unsafe input\n\nStep 3 — Choose a verdict: approve, request_changes, or comment\n\nOutput:\n{\"status\": \"success\", \"context_updates\": {\"review_body\": \"YOUR FULL REVIEW MARKDOWN\", \"review_verdict\": \"approve|request_changes|comment\", \"review_summary\": \"ONE-LINE SUMMARY\", \"review_pr_url\": \"THE PR URL\"}}\n\nCRITICAL: Your ENTIRE response must be ONLY the JSON object. No preamble, no explanation, no code fences."
    ]

    // Comment draft — writes bridge.* output for the GitHub issue
    comment_draft [
        label     = "Draft Comment",
        shape     = box,
        fillcolor = "#E8F0FE",
        prompt    = "Draft a GitHub issue comment summarizing the code review.\n\nReview verdict: $review_verdict\nReview summary: $review_summary\nPR URL: $review_pr_url\nFull review: $review_body\n\nInclude:\n- The verdict (approve/request_changes/comment)\n- Key findings from the review\n- Link to the PR\n\nOutput:\n{\"status\": \"success\", \"context_updates\": {\"bridge.comment\": \"YOUR COMMENT IN MARKDOWN\", \"bridge.summary\": \"ONE-LINE REVIEW SUMMARY\", \"bridge.labels\": [\"reviewed\"]}}\n\nCRITICAL: Your ENTIRE response must be ONLY the JSON object. No preamble, no explanation, no code fences."
    ]

    // Pipeline exit
    done [
        label     = "Done",
        shape     = Msquare,
        fillcolor = "#FFCDD2"
    ]

    // ═══════════════════════════════════════════════════════════
    // EDGES
    // ═══════════════════════════════════════════════════════════

    start -> code_review
    code_review -> comment_draft
    comment_draft -> done

}

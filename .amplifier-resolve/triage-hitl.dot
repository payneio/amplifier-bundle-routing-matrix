// triage-review-resolve-hitl.dot
//
// Pipeline: Resolve-Hosted Issue Triage — HITL (Human-in-the-Loop) Variant
//
// Flow:
//   1. Manager reads the issue and decides: simple, needs_clarification, or complex?
//   2. Simple:              manager drafts quick summary → comment_draft (skip investigation)
//   3. Complex:             manager → investigate → quality_eval loop (max 3 cycles)
//   4. Default (fallback):  manager → clarify (hexagon HITL pause) → investigate
//   5. comment_draft always runs last — writes bridge.* output for GitHub
//
// Variant of: triage-review-resolve.dot
// Changes from base graph:
//   - digraph name: triage_review_hitl
//   - default_thread_id: triage-hitl-thread
//   - Added clarify node (shape=hexagon, mode=freeform) — HITL pause point
//   - manager now routes to THREE outcomes instead of two:
//       (1) simple              → comment_draft  (unchanged)
//       (2) complex             → investigate      (conditional)
//       (3) fallback            → clarify          (unconditional — catches unstructured output)
//   - investigate now accepts optional $clarify_response context variable
//
// No bridge changes required:
//   - input_request handling for freeform HITL pauses already exists in bridge
//   - The clarify hexagon node uses 'description' (not 'prompt:'); the attractor
//     engine uses its description (and outgoing edge labels) as the question to human
//
// Adapted for Resolve-hosted execution:
//   - Repos are in workspace via Gitea mirrors (no checkout tools)
//   - Bridge handles all GitHub I/O (no direct GitHub tool calls)
//   - comment_draft writes bridge.* context_updates instead of calling tools
//   - Context ($goal) comes from bridge translator, not raw GitHub API

digraph triage_review_hitl {

    // — Graph-level attributes ————————————————————————————————————————————

    label             = "Issue Triage Review (HITL)"
    labelloc          = t
    rankdir           = TB
    compound          = true
    fontname          = "Helvetica"
    nodesep           = 0.6
    ranksep           = 0.9

    // Attractor pipeline configuration
    goal              = "$goal"
    default_fidelity  = "compact"
    default_thread_id = "triage-hitl-thread"

    // — Model stylesheet ——————————————————————————————————————————————————————
    model_stylesheet  = "quality_eval: model_role=reasoning reasoning_effort=high; manager: model_role=reasoning; investigate: model_role=general"

    // — Default node and edge styles ——————————————————————————————————————————
    node [fontname="Helvetica", fontsize=11, style="filled"]
    edge [fontname="Helvetica", fontsize=10, color="#555555"]

    // ═══════════════════════════════════════════════════════════════════════
    // PIPELINE NODES
    // ═══════════════════════════════════════════════════════════════════════

    // Entry point
    start [
        label     = "Start",
        shape     = Mdiamond,
        fillcolor = "#C8E6C9"
    ]

    // Manager — reads the issue, decides complexity, routes accordingly.
    // SIMPLE:              manager writes triage_summary and skips to comment_draft.
    // COMPLEX:             manager sets context.complexity=complex; routed to investigate.
    // FALLBACK (default):  routes to clarify (HITL pause) — catches ambiguous output too.
    manager [
        label      = "Manager",
        shape      = house,
        fillcolor  = "#D1C4E9",
        max_cycles = 3,
        prompt     = "You are a triage manager. Read the issue described in $goal.\n\nYour job is to assess complexity and route to one of THREE outcomes:\n\n1. READ the issue carefully.\n2. DECIDE: Is this simple, does it need clarification, or does it need deep investigation?\n\nCriteria for SIMPLE:\n  - The issue is a known pattern (missing docs, config error, clear user error)\n  - The root cause is obvious from the description\n  - No code verification is needed\n\nCriteria for NEEDS_CLARIFICATION:\n  - The issue is ambiguous or underspecified\n  - Key context is missing (version, repro steps, expected vs actual behavior)\n  - You have a specific question for the reporter that would determine the investigation path\n\nCriteria for COMPLEX (default fallback):\n  - The issue involves code behavior that needs verification\n  - Root cause is unclear or disputed\n  - Multiple modules or layers could be involved\n  - The reporter's framing needs independent verification against code\n\nOutput ONLY one of:\n\nIf SIMPLE:\n{\"status\": \"success\", \"context_updates\": {\"context.complexity\": \"simple\", \"triage_summary\": \"YOUR QUICK TRIAGE ANALYSIS HERE — include root cause assessment, recommendation, and confidence level\"}}\n\nIf NEEDS_CLARIFICATION:\n{\"status\": \"success\", \"context_updates\": {\"context.complexity\": \"needs_clarification\", \"clarify_prompt\": \"YOUR SPECIFIC QUESTION TO THE REPORTER HERE — be precise and ask only what you need to proceed\"}}\n\nIf COMPLEX:\n{\"status\": \"success\", \"context_updates\": {\"context.complexity\": \"complex\"}}"
    ]

    // HITL clarify node — pauses execution for human input from the issue reporter.
    // shape=hexagon marks this as a human-in-the-loop pause point.
    // mode=freeform means the attractor engine presents the description to the human
    // and waits for a free-text reply (captured as $clarify_response).
    //
    // NOTE: The description is STATIC — no $variable references.  The Resolve engine
    // does NOT expand $variables in hexagon `description` attributes (only in `prompt`
    // attributes fed to the LLM).  The bridge will replace this static description
    // with a richer message that includes the original issue context.
    clarify [
        label       = "Clarify with Reporter",
        shape       = hexagon,
        fillcolor   = "#FFE082",
        mode        = "freeform",
        description = "The triage manager needs more information before it can investigate this issue.\n\nPlease provide additional context: affected versions, reproduction steps, error messages, or any other details that would help narrow down the root cause.\n\nReply with `/resolve <your answer>`."
    ]

    // Investigation cycle subgraph
    subgraph cluster_investigation_cycle {
        label = "Investigation Cycle"
        style = dashed
        color = "#999999"

        // Investigator — independent root-cause analysis against actual code.
        // Repos are already in workspace via Gitea mirrors — no checkout tools needed.
        // $clarify_response is injected if the HITL clarify path was taken (may be empty).
        investigate [
            label     = "Investigate",
            shape     = box,
            fillcolor = "#E8F0FE",
            timeout   = "5m",
            prompt    = "You are investigating the issue described in $goal.\n\nThe relevant repositories are already cloned in your workspace via Gitea mirrors — no checkout tools are available or needed.\n\nAdditional context from reporter (if provided): $clarify_response\n\nSTEP 1 — Investigate:\n  - Read the issue. Verify every claim against actual code. Do NOT trust the reporter's framing.\n  - Perform independent verification of the root cause from source code.\n  - Check sibling modules for the same gap.\n  - If $clarify_response is non-empty, incorporate the reporter's answer into your analysis.\n\nSTEP 2 — Output:\nYour entire response must be ONLY this JSON:\n{\"status\": \"success\", \"context_updates\": {\"triage_summary\": \"YOUR COMPLETE FINDINGS HERE\"}}\n\nThe triage_summary must contain: Root cause file:line, Ecosystem layer, Sibling modules checked, Recommended fix, Fix layer."
        ]

        // Adversarial quality gate — evaluates investigate findings.
        quality_eval [
            label            = "Quality Gate",
            shape            = diamond,
            fillcolor        = "#FFF9C4",
            goal_gate        = true,
            timeout          = "2m",
            reasoning_effort = high,
            prompt           = "You are an adversarial quality gate. Evaluate the investigation findings.\n\nINVESTIGATION SUMMARY:\n$triage_summary\n\nEvaluate against these criteria:\n(1) INDEPENDENT VERIFICATION: Did the investigator verify from code independently, or just restate the issue? FAIL if no independent verification.\n(2) ECOSYSTEM-LAYER CORRECTNESS: Is the fix scoped to the correct layer? FAIL if wrong layer.\n(3) BLAST RADIUS: Were sibling modules checked? FAIL if not.\n(4) SPECIFICITY: Is root cause a specific file:line? Vague = FAIL.\n(5) RECOMMENDATION: One concrete recommendation. Menu of options = FAIL.\n\nOutput ONLY one of:\nOn FAIL: {\"status\": \"fail\", \"failure_reason\": \"Criterion N: reason\", \"context_updates\": {\"quality_feedback\": \"Fix these issues: ...\"}}\nOn SUCCESS: {\"status\": \"success\"}"
        ]
    }

    // Comment drafter — writes bridge.* output variables for the bridge to post.
    // Always runs as the final step before done, regardless of path taken.
    // Reads $triage_summary which is set by either manager (simple) or investigate (complex/HITL).
    comment_draft [
        label     = "Draft Comment",
        shape     = box,
        fillcolor = "#E8F0FE",
        prompt    = "The triage findings are in $triage_summary.\n\nWrite a triage analysis and output it as JSON with context_updates containing bridge output variables.\n\nStructure the comment as:\n- Lead with a 2-3 sentence plain-English summary of the root cause and recommended fix\n- If sibling modules were checked, show what was found\n- Give a single concrete recommendation, not options\n- Only report what was verified (from code if investigated, from issue context if triaged directly)\n\nYour entire response must be ONLY this JSON:\n{\"status\": \"success\", \"context_updates\": {\"bridge.comment\": \"YOUR TRIAGE COMMENT IN MARKDOWN\", \"bridge.status\": \"triaged\", \"bridge.summary\": \"ONE-LINE SUMMARY OF ROOT CAUSE AND FIX\", \"bridge.labels\": [\"bug\", \"triaged\"]}}\n\nDo NOT call any GitHub tools directly. The bridge reads these bridge.* variables and handles all GitHub I/O."
    ]

    // Pipeline exit
    done [
        label     = "Done",
        shape     = Msquare,
        fillcolor = "#FFCDD2"
    ]

    // ═══════════════════════════════════════════════════════════════════════
    // EDGES
    // ═══════════════════════════════════════════════════════════════════════

    start -> manager

    // SIMPLE: manager can triage directly — skip investigation.
    // Only fires when manager explicitly sets context.complexity=simple.
    manager -> comment_draft [
        label     = "simple",
        condition = "context.complexity=simple",
        color     = "#43A047",
        fontcolor = "#43A047"
    ]

    // COMPLEX: deep investigation needed — code verification required.
    // Only fires when manager explicitly sets context.complexity=complex.
    manager -> investigate [
        label     = "complex",
        condition = "context.complexity=complex",
        color     = "#1565C0",
        fontcolor = "#1565C0"
    ]

    // FALLBACK: clarify is the safe default.
    // Unconditional — catches needs_clarification, unstructured LLM output,
    // and any other case where the manager didn't explicitly route.
    // Asking the human is always safer than silently investigating.
    manager -> clarify [
        label = "needs_clarification"
    ]

    // After human replies, proceed to investigation with $clarify_response injected.
    clarify -> investigate

    investigate -> quality_eval [
        thread_id = "quality-thread",
        fidelity  = "compact"
    ]

    // SUCCESS: quality approved — move to comment drafting
    quality_eval -> comment_draft [
        label     = "outcome=success",
        condition = "outcome=success",
        color     = "#43A047",
        fontcolor = "#43A047"
    ]

    // FAIL: quality rejected — investigator retries with critique
    quality_eval -> investigate [
        label     = "outcome!=success",
        condition = "outcome!=success",
        style     = dashed,
        color     = "#E57373",
        fontcolor = "#E57373"
    ]

    comment_draft -> done

}

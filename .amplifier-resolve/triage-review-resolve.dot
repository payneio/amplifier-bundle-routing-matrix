// triage-review-resolve.dot
//
// Pipeline: Resolve-Hosted Issue Triage — Manager-Supervised Pattern
//
// Flow:
//   1. Manager reads the issue and decides: simple or complex?
//   2. Simple: manager drafts a quick summary, skips to comment_draft
//   3. Complex: investigate -> quality_eval loop (max 3 cycles)
//   4. comment_draft always runs last — writes bridge.* output for GitHub
//
// Adapted for Resolve-hosted execution:
//   - Repos are in workspace via Gitea mirrors (no checkout tools)
//   - Bridge handles all GitHub I/O (no direct GitHub tool calls)
//   - comment_draft writes bridge.* context_updates instead of calling tools
//   - Context ($goal) comes from bridge translator, not raw GitHub API

digraph triage_review {

    // — Graph-level attributes ————————————————————————————————

    label             = "Issue Triage Review"
    labelloc          = t
    rankdir           = TB
    compound          = true
    fontname          = "Helvetica"
    nodesep           = 0.6
    ranksep           = 0.9

    // Attractor pipeline configuration
    goal              = "$goal"
    default_fidelity  = "compact"
    default_thread_id = "triage-thread"

    // — Model stylesheet ——————————————————————————————————————
    model_stylesheet  = "quality_eval: model_role=reasoning reasoning_effort=high; manager: model_role=reasoning; investigate: model_role=general"

    // — Default node and edge styles —————————————————————————
    node [fontname="Helvetica", fontsize=11, style="filled"]
    edge [fontname="Helvetica", fontsize=10, color="#555555"]

    // ═══════════════════════════════════════════════════════════
    // PIPELINE NODES
    // ═══════════════════════════════════════════════════════════

    // Entry point
    start [
        label     = "Start",
        shape     = Mdiamond,
        fillcolor = "#C8E6C9"
    ]

    // Manager — reads the issue, decides complexity, routes accordingly.
    // Simple issues: manager writes a quick triage_summary and skips to comment_draft.
    // Complex issues: routes to the investigation cycle for deep analysis.
    manager [
        label     = "Manager",
        shape     = box,
        fillcolor = "#D1C4E9",
        max_cycles = 3,
        prompt    = "You are a triage manager. Read the issue described in $goal.\n\nYour job is to assess complexity and route:\n\n1. READ the issue carefully.\n2. DECIDE: Can this be triaged from the issue description alone, or does it need code investigation?\n\nCriteria for SIMPLE:\n  - The issue is a known pattern (missing docs, config error, clear user error)\n  - The root cause is obvious from the description\n  - No code verification is needed\n\nCriteria for COMPLEX:\n  - The issue involves code behavior that needs verification\n  - Root cause is unclear or disputed\n  - Multiple modules or layers could be involved\n  - The reporter's framing needs independent verification against code\n\nOutput ONLY one of:\n\nIf SIMPLE:\n{\"status\": \"success\", \"context_updates\": {\"context.complexity\": \"simple\", \"triage_summary\": \"YOUR QUICK TRIAGE ANALYSIS HERE — include root cause assessment, recommendation, and confidence level\"}}\n\nIf COMPLEX:\n{\"status\": \"success\", \"context_updates\": {\"context.complexity\": \"complex\"}}"
    ]

    // Investigation cycle subgraph
    subgraph cluster_investigation_cycle {
        label     = "Investigation Cycle"
        style     = dashed
        color     = "#999999"

        // Investigator — independent root-cause analysis against actual code.
        // Repos are already in workspace via Gitea mirrors — no checkout tools needed.
        investigate [
            label     = "Investigate",
            shape     = box,
            fillcolor = "#E8F0FE",
            timeout   = "5m",
            prompt    = "You are investigating the issue described in $goal.\n\nThe relevant repositories are already cloned in your workspace via Gitea mirrors — no checkout tools are available or needed.\n\nSTEP 1 — Investigate:\n  - Read the issue. Verify every claim against actual code. Do NOT trust the reporter's framing.\n  - Perform independent verification of the root cause from source code.\n  - Check sibling modules for the same gap.\n\nSTEP 2 — Output:\nYour entire response must be ONLY this JSON:\n{\"status\": \"success\", \"context_updates\": {\"triage_summary\": \"YOUR COMPLETE FINDINGS HERE\"}}\n\nThe triage_summary must contain: Root cause file:line, Ecosystem layer, Sibling modules checked, Recommended fix, Fix layer."
        ]

        // Adversarial quality gate — evaluates investigate findings.
        quality_eval [
            label            = "Quality Gate",
            shape            = diamond,
            fillcolor        = "#FFF9C4",
            goal_gate        = true,
            timeout          = "2m",
            reasoning_effort = high,
            prompt           = "You are an adversarial quality gate. Evaluate the investigation findings.\n\nINVESTIGATION SUMMARY:\n$triage_summary\n\nEvaluate against these criteria:\n(1) INDEPENDENT VERIFICATION: Did the investigator verify from code independently, or just restate the issue? FAIL if no independent verification.\n(2) ECOSYSTEM-LAYER CORRECTNESS: Is the fix scoped to the correct layer? FAIL if wrong layer.\n(3) BLAST RADIUS: Were sibling modules checked? FAIL if not.\n(4) SPECIFICITY: Is root cause a specific file:line? Vague = FAIL.\n(5) RECOMMENDATION: One concrete recommendation. Menu of options = FAIL.\n\nOutput ONLY one of:\nOn FAIL: {\"status\": \"fail\", \"failure_reason\": \"Criterion N: reason\", \"context_updates\": {\"quality_feedback\": \"Fix these issues: ...\"}}\nOn SUCCESS: {\"status\": \"success\"}"
        ]
    }

    // Comment drafter — writes bridge.* output variables for the bridge to post.
    // Always runs as the final step before done, regardless of path taken.
    // Reads $triage_summary which is set by either manager (simple) or investigate (complex).
    comment_draft [
        label     = "Draft Comment",
        shape     = box,
        fillcolor = "#E8F0FE",
        prompt    = "The triage findings are in $triage_summary.\n\nWrite a triage analysis and output it as JSON with context_updates containing bridge output variables.\n\nStructure the comment as:\n- Lead with a 2-3 sentence plain-English summary of the root cause and recommended fix\n- If sibling modules were checked, show what was found\n- Give a single concrete recommendation, not options\n- Only report what was verified (from code if investigated, from issue context if triaged directly)\n\nYour entire response must be ONLY this JSON:\n{\"status\": \"success\", \"context_updates\": {\"bridge.comment\": \"YOUR TRIAGE COMMENT IN MARKDOWN\", \"bridge.status\": \"triaged\", \"bridge.summary\": \"ONE-LINE SUMMARY OF ROOT CAUSE AND FIX\", \"bridge.labels\": [\"bug\", \"triaged\"]}}\n\nDo NOT call any GitHub tools directly. The bridge reads these bridge.* variables and handles all GitHub I/O."
    ]

    // Pipeline exit
    done [
        label     = "Done",
        shape     = Msquare,
        fillcolor = "#FFCDD2"
    ]

    // ═══════════════════════════════════════════════════════════
    // EDGES
    // ═══════════════════════════════════════════════════════════

    start -> manager

    // SIMPLE: manager can triage directly — skip investigation.
    // Only fires when manager explicitly sets context.complexity=simple.
    manager -> comment_draft [
        label     = "simple",
        condition = "context.complexity=simple",
        color     = "#43A047",
        fontcolor = "#43A047"
    ]

    // COMPLEX or fallback: investigate is the safe default.
    // Unconditional — catches both explicit "complex" routing AND
    // cases where the LLM output wasn't parsed as structured JSON.
    manager -> investigate [
        label     = "complex"
    ]

    investigate -> quality_eval [
        thread_id = "quality-thread",
        fidelity  = "compact"
    ]

    // SUCCESS: quality approved — move to comment drafting
    quality_eval -> comment_draft [
        label     = "outcome=success",
        condition = "outcome=success",
        color     = "#43A047",
        fontcolor = "#43A047"
    ]

    // FAIL: quality rejected — investigator retries with critique
    quality_eval -> investigate [
        label     = "outcome!=success",
        condition = "outcome!=success",
        style     = dashed,
        color     = "#E57373",
        fontcolor = "#E57373"
    ]

    comment_draft -> done

}

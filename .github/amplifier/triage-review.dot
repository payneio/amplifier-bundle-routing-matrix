// triage-review.dot
//
// Pipeline: Automated GitHub Issue Triage — Flat Supervisor-Free Pattern
//
// ARCHITECTURE: Each node is a top-level pipeline node with its own spawned
// child session. No shape=house manager. This gives full visibility:
//   [PIPELINE] ▶ investigate [box]
//   [PIPELINE] ▶ quality_eval [diamond]
//   [PIPELINE] -> edge: quality_eval --[outcome!=success]--> investigate  (retry)
//   [PIPELINE] -> edge: quality_eval --[outcome=success]--> comment_draft (pass)
//
// Threads:
//   triage-thread  — investigate + comment_draft (context accumulates across cycles)
//   quality-thread — quality_eval only (fresh adversarial context each cycle)
//
// Cycle limit: quality_eval.timeout=2m + investigate.timeout=5m naturally
// bounds each cycle. goal_gate=true on quality_eval tracks overall success.

digraph triage_review {

    // ── Graph-level attributes ───────────────────────────────────────────────

    label             = "Issue Triage Review"
    labelloc          = t
    rankdir           = TB
    compound          = true
    fontname          = "Helvetica"
    nodesep           = 0.6
    ranksep           = 0.9

    // Attractor pipeline configuration
    goal              = "Triage the GitHub issue described in the conversation context"
    default_fidelity  = "truncate"
    default_thread_id = "triage-thread"

    // ── Default node and edge styles ─────────────────────────────────────────
    node [fontname="Helvetica", fontsize=11, style="filled"]
    edge [fontname="Helvetica", fontsize=10, color="#555555"]

    // ═══════════════════════════════════════════════════════════════════════
    // PIPELINE NODES — all top-level, each gets its own child session
    // ═══════════════════════════════════════════════════════════════════════

    // Entry point
    start [
        label     = "Start",
        shape     = Mdiamond,
        fillcolor = "#C8E6C9"
    ]

    // Investigator — independent root-cause analysis against actual code.
    // Runs on triage-thread so it sees steering from prior quality_eval cycles.
    // MUST NOT post any GitHub comment — findings go to quality_eval only.
    investigate [
        label     = "Investigate",
        shape     = box,
        fillcolor = "#E8F0FE",
        timeout   = "7m",
        prompt    = "IMPORTANT: Do NOT post any comments to GitHub via any mechanism. Output your findings as text only.\n\nQUALITY GATE FEEDBACK FROM PREVIOUS CYCLE (empty on first run):\n$quality_feedback\n\nIf the above feedback is non-empty, your previous investigation failed. Read the feedback carefully and specifically address each failure before doing anything else.\n\nSTEP 1 — LOAD CONTEXT (do this before anything else):\n  a) curl -s https://raw.githubusercontent.com/microsoft/amplifier/main/context/ecosystem-overview.md\n  b) curl -s https://raw.githubusercontent.com/microsoft/amplifier/main/docs/MODULES.md\n  c) read_file: /home/runner/work/amplifier-actions-example/amplifier-actions-example/.github/amplifier/triage-context.md\n     (if that path fails, try: github_checkout_repo owner=kenotron-ms repo=amplifier-actions-example, then read .github/amplifier/triage-context.md)\nThe triage-context.md has the FULL investigation principles and required output format — follow it exactly.\n\nSTEP 2 — WRITE YOUR SUMMARY BLOCK FIRST (before diving into details):\nImmediately after loading context, write the ## Summary block from triage-context.md with your best current hypothesis. Update it as you investigate. This ensures quality_eval sees a complete report even if you run short on time.\n\nSTEP 3 — INVESTIGATE the issue in $goal:\n  - Read the issue description but DO NOT trust it. Verify every claim against the actual source code.\n  - Especially: if the reporter says an exception is 'unhandled', check whether the CALLER already has a try/except. Trace upward through the call chain.\n  - Use github_checkout_repo with owner='microsoft' for relevant repos.\n\nSTEP 4 — CHECK SIBLING MODULES (required):\n  For any provider issue: checkout and check ALL of these: amplifier-module-provider-openai, provider-gemini, provider-azure-openai, provider-vllm, provider-ollama, provider-github-copilot.\n  For each: does the same gap exist? Note file:line.\n\nSTEP 5 — FINALIZE your ## Summary block with definitive findings, then provide supporting evidence."
    ]

    // Adversarial quality gate — evaluates investigate findings.
    // Runs on quality-thread (fresh context) for genuine independence.
    // Calls report_outcome(outcome='success'|'fail', reason='...').
    quality_eval [
        label            = "Quality Gate",
        shape            = diamond,
        fillcolor        = "#FFF9C4",
        goal_gate        = true,
        retry_target     = "investigate",
        timeout          = "3m",
        reasoning_effort = high,
        prompt           = "You are an adversarial reviewer. Evaluate the investigator's findings against all six criteria. Do all your reasoning in thinking and tool calls — your FINAL TEXT RESPONSE must be ONLY a raw JSON object, nothing else. No markdown. No explanation. No prose. No code fences.\n\nSix criteria to check:\n(1) PROXY CHECK: Did the investigator anchor on prior issue comments or reporter framing without independent code verification? FAIL if so.\n(2) SPECIFICITY: Is root cause pinned to a specific file:line? 'Probably in this function' = FAIL.\n(3) LAYER CHECK: Ecosystem hierarchy (innermost→outermost): amplifier-core → amplifier-module-* → amplifier-foundation → amplifier-bundle-* → amplifier-app-cli. If fix is scoped to one provider but root cause affects all providers, fix belongs higher. Ask: who does this NOT protect?\n(4) DIMENSIONALITY: Did investigator check sibling modules for the same issue? Only looking at one provider when multiple exist = FAIL.\n(5) RECOMMENDATION: Concrete recommendation required. List of options = FAIL.\n(6) STRUCTURE: Output must lead with conclusion in plain English. Buried findings = FAIL.\n\nThen your FINAL TEXT RESPONSE must be ONLY one of these two JSON objects — no other text before or after.\n\nOn FAIL — include context_updates so feedback is injected into the next investigate cycle:\n{\"status\": \"fail\", \"failure_reason\": \"Criterion N: specific reason\", \"context_updates\": {\"quality_feedback\": \"QUALITY GATE FAILED. Fix these specific issues in your next investigation:\\n- [criterion name]: [what was wrong and exactly what to do differently]\"}}\n\nOn SUCCESS:\n{\"status\": \"success\"}\n\nDo NOT write report_outcome(...) as text in your response. Do NOT add markdown. The pipeline reads your final text as JSON to route. Plain text routes to success regardless of what you write."
    ]

    // Drafter + poster — writes and posts the final GitHub comment.
    // Uses commenter profile (has github_post_comment).
    // Runs on triage-thread so it sees the full investigation history.
    comment_draft [
        label        = "Post Analysis",
        shape        = box,
        fillcolor    = "#E8F0FE",
        llm_provider = "anthropic-commenter",
        prompt       = "The GitHub issue is described in $goal — extract the owner, repo name, and issue number from it. Write a final triage comment and post it to that issue using github_post_comment. Structure it inductively: lead with a 2-3 sentence plain-English summary of the root cause and recommended fix (no jargon), then provide supporting evidence. Be direct — give a recommendation, not a menu of options. Only report what was independently verified through code, not what prior comments suggested."
    ]

    // Pipeline exit
    done [
        label     = "Done",
        shape     = Msquare,
        fillcolor = "#FFCDD2"
    ]

    // ═══════════════════════════════════════════════════════════════════════
    // EDGES
    // ═══════════════════════════════════════════════════════════════════════

    start -> investigate

    // Investigator delivers findings to quality gate.
    // quality-thread = fresh adversarial context (compact summary only).
    investigate -> quality_eval [
        thread_id = "quality-thread"
    ]

    // SUCCESS: quality approved — move to drafting and posting the comment.
    quality_eval -> comment_draft [
        label     = "outcome=success",
        condition = "outcome=success",
        color     = "#43A047",
        fontcolor = "#43A047"
    ]

    // FAIL: quality rejected — investigator retries with critique in context.
    // triage-thread: investigator sees the quality_eval failure reason.
    quality_eval -> investigate [
        label     = "outcome!=success",
        condition = "outcome!=success",
        style     = dashed,
        color     = "#E57373",
        fontcolor = "#E57373"
    ]

    comment_draft -> done

}

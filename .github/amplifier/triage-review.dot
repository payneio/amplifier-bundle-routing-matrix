// triage-review.dot
//
// Pipeline: Automated GitHub Issue Triage — Flat Supervisor-Free Pattern
//
// ARCHITECTURE: Each node is a top-level pipeline node with its own spawned
// child session. No shape=house manager. This gives full visibility:
//   [PIPELINE] ▶ investigate [box]
//   [PIPELINE] ▶ quality_eval [diamond]
//   [PIPELINE] -> edge: quality_eval --[outcome!=success]--> investigate  (retry)
//   [PIPELINE] -> edge: quality_eval --[outcome=success]--> comment_draft (pass)
//
// Threads:
//   triage-thread  — investigate + comment_draft (context accumulates across cycles)
//   quality-thread — quality_eval only (fresh adversarial context each cycle)
//
// Cycle limit: quality_eval.timeout=2m + investigate.timeout=5m naturally
// bounds each cycle. goal_gate=true on quality_eval tracks overall success.

digraph triage_review {

    // ── Graph-level attributes ───────────────────────────────────────────────

    label             = "Issue Triage Review"
    labelloc          = t
    rankdir           = TB
    compound          = true
    fontname          = "Helvetica"
    nodesep           = 0.6
    ranksep           = 0.9

    // Attractor pipeline configuration
    goal              = "Triage the GitHub issue described in the conversation context"
    default_fidelity  = "full"
    default_thread_id = "triage-thread"

    // ── Default node and edge styles ─────────────────────────────────────────
    node [fontname="Helvetica", fontsize=11, style="filled"]
    edge [fontname="Helvetica", fontsize=10, color="#555555"]

    // ═══════════════════════════════════════════════════════════════════════
    // PIPELINE NODES — all top-level, each gets its own child session
    // ═══════════════════════════════════════════════════════════════════════

    // Entry point
    start [
        label     = "Start",
        shape     = Mdiamond,
        fillcolor = "#C8E6C9"
    ]

    // Investigator — independent root-cause analysis against actual code.
    // Runs on triage-thread so it sees steering from prior quality_eval cycles.
    // MUST NOT post any GitHub comment — findings go to quality_eval only.
    investigate [
        label     = "Investigate",
        shape     = box,
        fillcolor = "#E8F0FE",
        timeout   = "5m",
        prompt    = "IMPORTANT: Do NOT post any comments to GitHub via any mechanism (github_post_comment, gh CLI, bash, curl, or any other tool). Output your findings as text only — quality_eval will evaluate them.\n\nSTEP 1 — LOAD ECOSYSTEM CONTEXT FIRST. Before investigating, fetch these two files:\n  curl -s https://raw.githubusercontent.com/microsoft/amplifier/main/context/ecosystem-overview.md\n  curl -s https://raw.githubusercontent.com/microsoft/amplifier/main/docs/MODULES.md\nThese tell you every repo in the ecosystem, the layer hierarchy (amplifier-core → amplifier-module-* → amplifier-foundation → amplifier-bundle-* → amplifier-app-cli), and which provider/tool/hook modules exist. Use this map to know where to look and which sibling modules to check.\n\nSTEP 2 — INVESTIGATE. Investigate the GitHub issue in $goal. Do not anchor your analysis on any prior comments in the issue thread. Form your own hypotheses and test them against the actual code. Use github_checkout_repo with owner='microsoft' to check out any relevant repos.\n\nSTEP 3 — CHECK SIBLINGS. If the issue involves a module type (e.g. a provider), check ALL sibling modules of that type listed in MODULES.md for the same issue. A finding that only looks at one provider when four exist is incomplete.\n\nReport: root cause with file:line, affected ecosystem layer/repo, whether sibling modules have the same issue, and a concrete recommendation."
    ]

    // Adversarial quality gate — evaluates investigate findings.
    // Runs on quality-thread (fresh context) for genuine independence.
    // Calls report_outcome(outcome='success'|'fail', reason='...').
    quality_eval [
        label            = "Quality Gate",
        shape            = diamond,
        fillcolor        = "#FFF9C4",
        goal_gate        = true,
        timeout          = "2m",
        reasoning_effort = high,
        prompt           = "You are an adversarial reviewer. Evaluate the investigator's findings against all six criteria. Do all your reasoning in thinking and tool calls — your FINAL TEXT RESPONSE must be ONLY a raw JSON object, nothing else. No markdown. No explanation. No prose. No code fences.\n\nSix criteria to check:\n(1) PROXY CHECK: Did the investigator anchor on prior issue comments or reporter framing without independent code verification? FAIL if so.\n(2) SPECIFICITY: Is root cause pinned to a specific file:line? 'Probably in this function' = FAIL.\n(3) LAYER CHECK: Ecosystem hierarchy (innermost→outermost): amplifier-core → amplifier-module-* → amplifier-foundation → amplifier-bundle-* → amplifier-app-cli. If fix is scoped to one provider but root cause affects all providers, fix belongs higher. Ask: who does this NOT protect?\n(4) DIMENSIONALITY: Did investigator check sibling modules for the same issue? Only looking at one provider when multiple exist = FAIL.\n(5) RECOMMENDATION: Concrete recommendation required. List of options = FAIL.\n(6) STRUCTURE: Output must lead with conclusion in plain English. Buried findings = FAIL.\n\nAfter evaluating, call report_outcome(status='fail', failure_reason='...') or report_outcome(status='success').\n\nThen your FINAL TEXT RESPONSE must be ONLY one of these two JSON objects — no other text before or after:\n{\"status\": \"fail\", \"failure_reason\": \"Criterion N: specific reason\"}\n{\"status\": \"success\"}\n\nDo NOT write report_outcome(...) as text in your response. Do NOT add markdown. The pipeline reads your final text as JSON to route. Plain text routes to success regardless of what you write."
    ]

    // Drafter + poster — writes and posts the final GitHub comment.
    // Uses commenter profile (has github_post_comment).
    // Runs on triage-thread so it sees the full investigation history.
    comment_draft [
        label        = "Post Analysis",
        shape        = box,
        fillcolor    = "#E8F0FE",
        llm_provider = "anthropic-commenter",
        prompt       = "The GitHub issue is described in $goal — extract the owner, repo name, and issue number from it. Write a final triage comment and post it to that issue using github_post_comment. Structure it inductively: lead with a 2-3 sentence plain-English summary of the root cause and recommended fix (no jargon), then provide supporting evidence. Be direct — give a recommendation, not a menu of options. Only report what was independently verified through code, not what prior comments suggested."
    ]

    // Pipeline exit
    done [
        label     = "Done",
        shape     = Msquare,
        fillcolor = "#FFCDD2"
    ]

    // ═══════════════════════════════════════════════════════════════════════
    // EDGES
    // ═══════════════════════════════════════════════════════════════════════

    start -> investigate

    // Investigator delivers findings to quality gate.
    // quality-thread = fresh adversarial context (compact summary only).
    investigate -> quality_eval [
        thread_id = "quality-thread",
        fidelity  = "full"
    ]

    // SUCCESS: quality approved — move to drafting and posting the comment.
    quality_eval -> comment_draft [
        label     = "outcome=success",
        condition = "outcome=success",
        color     = "#43A047",
        fontcolor = "#43A047"
    ]

    // FAIL: quality rejected — investigator retries with critique in context.
    // triage-thread: investigator sees the quality_eval failure reason.
    quality_eval -> investigate [
        label     = "outcome!=success",
        condition = "outcome!=success",
        thread_id = "triage-thread",
        style     = dashed,
        color     = "#E57373",
        fontcolor = "#E57373"
    ]

    comment_draft -> done

}

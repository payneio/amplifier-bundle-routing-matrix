// triage-dynamic.dot
//
// Pipeline: Dynamic HITL Issue Triage — Multi-Turn Clarification Pattern
//
// Flow:
//   1. Manager reads the issue and decides: simple, needs_clarification, or complex?
//   2. Simple:              manager drafts quick summary → comment_draft (skip investigation)
//   3. Needs clarification: manager → refine_question → ask_human → process_answer →
//                           check_clarify_done loop until READY_TO_INVESTIGATE sentinel
//   4. Default (fallback):  manager → refine_question (clarify is the safe default for vague issues)
//   5. comment_draft always runs last — writes bridge.* output for GitHub
//
// Key differences from triage-review-resolve-hitl.dot:
//   - Clarification is a LOOP (refine_question → ask_human → process_answer →
//     check_clarify_done), not a single HITL pause
//   - refine_question writes structured questions to docs/triage/clarify.md
//   - ask_human attaches that file inline so the human sees structured questions
//   - process_answer reads ${human.gate.text} and integrates the reply
//   - check_clarify_done uses a tool_command to grep for READY_TO_INVESTIGATE sentinel
//   - discover_repos is an explicit node that reads $goal and runs git clone
//   - manager routes to refine_question as the unconditional fallback (clarify is the safe default)
//
// Adapted for Resolve-hosted execution:
//   - Repos are in workspace via Gitea mirrors (no checkout tools)
//   - Bridge handles all GitHub I/O (no direct GitHub tool calls)
//   - comment_draft writes bridge.* context_updates instead of calling tools
//   - Context ($goal) comes from bridge translator, not raw GitHub API

digraph triage_dynamic {

    // — Graph-level attributes ——————————————————————————————————————————

    label             = "Issue Triage Review (Dynamic HITL)"
    description       = "Investigate and analyze an issue -- identify root cause, check sibling modules, and post findings with optional multi-turn clarification"
    labelloc          = t
    rankdir           = TB
    compound          = true
    fontname          = "Helvetica"
    nodesep           = 0.6
    ranksep           = 0.9

    // Attractor pipeline configuration
    goal              = "$goal"
    default_fidelity  = "compact"
    default_thread_id = "triage-dynamic-thread"

    // — Model stylesheet ————————————————————————————————————————————————
    // Covers all decision-bearing and new nodes:
    //   quality_eval  — adversarial gate, needs reasoning + high effort
    //   manager       — complexity triage, needs reasoning
    //   investigate   — code investigation, general model
    //   refine_question — question refinement, general model
    //   process_answer  — answer integration, general model
    //   discover_repos  — repo discovery, general model
    model_stylesheet  = "quality_eval: model_role=reasoning reasoning_effort=high; manager: model_role=reasoning; investigate: model_role=general; refine_question: model_role=general; process_answer: model_role=general; discover_repos: model_role=general"

    // — Default node and edge styles ————————————————————————————————————
    node [fontname="Helvetica", fontsize=11, style="filled"]
    edge [fontname="Helvetica", fontsize=10, color="#555555"]

    // ═══════════════════════════════════════════════════════════════════
    // PIPELINE NODES
    // ═══════════════════════════════════════════════════════════════════

    // Entry point
    start [
        label     = "Start",
        shape     = Mdiamond,
        fillcolor = "#C8E6C9"
    ]

    // Manager — reads the issue, decides complexity, routes accordingly.
    // SIMPLE:              manager writes triage_summary and skips to comment_draft.
    // COMPLEX:             routes to discover_repos for deep investigation.
    // FALLBACK (default):  routes to refine_question — asking for clarification is the safe default.
    manager [
        label      = "Manager",
        shape      = house,
        fillcolor  = "#D1C4E9",
        max_cycles = 3,
        prompt     = "You are a triage manager. Read the issue described in $goal.\n\nYour job is to assess complexity and route to one of THREE outcomes:\n\n1. READ the issue carefully.\n2. DECIDE: Is this simple, does it need clarification, or does it need deep investigation?\n\nCriteria for SIMPLE:\n  - The issue is a known pattern (missing docs, config error, clear user error)\n  - The root cause is obvious from the description\n  - No code verification is needed\n\nCriteria for NEEDS_CLARIFICATION:\n  - The issue is ambiguous or underspecified\n  - Key context is missing (version, repro steps, expected vs actual behavior)\n  - You have a specific question for the reporter that would determine the investigation path\n\nCriteria for COMPLEX (default fallback):\n  - The issue involves code behavior that needs verification\n  - Root cause is unclear or disputed\n  - Multiple modules or layers could be involved\n  - The reporter's framing needs independent verification against code\n\nOutput ONLY one of:\n\nIf SIMPLE:\n{\"status\": \"success\", \"context_updates\": {\"context.complexity\": \"simple\", \"triage_summary\": \"YOUR QUICK TRIAGE ANALYSIS HERE — include root cause assessment, recommendation, and confidence level\"}}\n\nIf NEEDS_CLARIFICATION:\n{\"status\": \"success\", \"context_updates\": {\"context.complexity\": \"needs_clarification\", \"clarify_prompt\": \"YOUR SPECIFIC QUESTION TO THE REPORTER HERE — be precise and ask only what you need to proceed\"}}\n\nIf COMPLEX:\n{\"status\": \"success\", \"context_updates\": {\"context.complexity\": \"complex\"}}"
    ]

    // ── Clarification loop subgraph ───────────────────────────────────
    subgraph cluster_clarify_loop {
        label = "Clarification Loop"
        style = dashed
        color = "#FF9800"

        // Refine Question — reads the issue context plus any prior answers and
        // writes a structured list of questions to docs/triage/clarify.md.
        // Loops up to 5 times (one round of questions per cycle).
        refine_question [
            label      = "Refine Question",
            shape      = box,
            fillcolor  = "#E8F0FE",
            max_cycles = 5,
            prompt     = "You are a clarification specialist. Read the issue in $goal and any prior answers in $clarify_answers.\n\nYour job is to write clear, structured questions that will help determine the investigation path.\n\nWrite your questions to docs/triage/clarify.md in this format:\n\n## Clarification Questions\n\n1. [Your first question — be specific]\n2. [Your second question — if needed]\n\nIf you have gathered enough information to proceed, write:\n\n## READY_TO_INVESTIGATE\n\nThe clarification is complete. Proceeding to investigation.\n\nOutput:\n{\"status\": \"success\", \"context_updates\": {\"clarify_questions\": \"YOUR QUESTIONS SUMMARY\"}}"
        ]

        // Ask Human — HITL pause point.
        // shape=hexagon marks this as a human-in-the-loop pause point.
        // mode=freeform means the attractor engine presents the description to
        // the human and waits for a free-text reply.
        // attachments_inline includes the structured questions file so the human
        // sees exactly what is being asked.
        ask_human [
            label              = "Ask Human",
            shape              = hexagon,
            fillcolor          = "#FFE082",
            mode               = "freeform",
            attachments_inline = "docs/triage/clarify.md",
            description        = "The triage manager needs more information before it can investigate this issue.\n\nPlease review the attached questions and provide your answers.\n\nReply with `/resolve <your answer>`."
        ]

        // Process Answer — reads the human's reply from ${human.gate.text}
        // and integrates it with existing context.
        process_answer [
            label     = "Process Answer",
            shape     = box,
            fillcolor = "#E8F0FE",
            prompt    = "You are processing the human's reply to clarification questions.\n\nHuman's reply:\n${human.gate.text}\n\nPrevious questions:\n$clarify_questions\n\nIntegrate the answer into the investigation context. Determine if we have enough information to proceed or if more questions are needed.\n\nOutput:\n{\"status\": \"success\", \"context_updates\": {\"clarify_answers\": \"INTEGRATED ANSWERS SO FAR\", \"clarify_status\": \"If all key questions are answered write READY_TO_INVESTIGATE, otherwise describe what is still missing\"}}"
        ]

        // Check Clarify Done — uses a tool_command to grep docs/triage/clarify.md
        // for the READY_TO_INVESTIGATE sentinel to decide whether to loop or proceed.
        check_clarify_done [
            label        = "Check Clarify Done",
            shape        = parallelogram,
            fillcolor    = "#E1BEE7",
            tool_command = "#!/bin/sh\nif grep -q READY_TO_INVESTIGATE docs/triage/clarify.md 2>/dev/null; then\n  printf 'done'\nelse\n  printf 'more_questions'\nfi"
        ]
    }

    // Discover Repos — reads $goal to identify relevant repositories
    // and runs git clone to ensure they are available in the workspace.
    discover_repos [
        label     = "Discover Repos",
        shape     = box,
        fillcolor = "#E8F0FE",
        prompt    = "You are preparing the workspace for investigation.\n\nRead the issue in $goal and identify which repositories are relevant.\n\nThe repositories may already be available in the workspace via Gitea mirrors. Check what is available and clone any that are missing.\n\nOutput:\n{\"status\": \"success\", \"context_updates\": {\"repos_available\": \"LIST OF REPOS NOW IN WORKSPACE\"}}"
    ]

    // Investigation cycle subgraph
    subgraph cluster_investigation_cycle {
        label = "Investigation Cycle"
        style = dashed
        color = "#999999"

        // Investigator — independent root-cause analysis against actual code.
        // Repos are already in workspace via Gitea mirrors — no checkout tools needed.
        // $clarify_answers is injected if the clarification loop was taken (may be empty).
        investigate [
            label     = "Investigate",
            shape     = box,
            fillcolor = "#E8F0FE",
            timeout   = "5m",
            prompt    = "You are investigating the issue described in $goal.\n\nThe relevant repositories are already cloned in your workspace via Gitea mirrors — no checkout tools are available or needed.\n\nAdditional context from clarification (if provided): $clarify_answers\nRepos available: $repos_available\n\nSTEP 1 — Investigate:\n  - Read the issue. Verify every claim against actual code. Do NOT trust the reporter's framing.\n  - Perform independent verification of the root cause from source code.\n  - Check sibling modules for the same gap.\n  - If $clarify_answers is non-empty, incorporate the reporter's answers into your analysis.\n\nSTEP 2 — Output:\nYour entire response must be ONLY this JSON:\n{\"status\": \"success\", \"context_updates\": {\"triage_summary\": \"YOUR COMPLETE FINDINGS HERE\"}}\n\nThe triage_summary must contain: Root cause file:line, Ecosystem layer, Sibling modules checked, Recommended fix, Fix layer."
        ]

        // Adversarial quality gate — evaluates investigate findings.
        quality_eval [
            label            = "Quality Gate",
            shape            = diamond,
            fillcolor        = "#FFF9C4",
            goal_gate        = true,
            timeout          = "2m",
            reasoning_effort = high,
            prompt           = "You are an adversarial quality gate. Evaluate the investigation findings.\n\nINVESTIGATION SUMMARY:\n$triage_summary\n\nEvaluate against these criteria:\n(1) INDEPENDENT VERIFICATION: Did the investigator verify from code independently, or just restate the issue? FAIL if no independent verification.\n(2) ECOSYSTEM-LAYER CORRECTNESS: Is the fix scoped to the correct layer? FAIL if wrong layer.\n(3) BLAST RADIUS: Were sibling modules checked? FAIL if not.\n(4) SPECIFICITY: Is root cause a specific file:line? Vague = FAIL.\n(5) RECOMMENDATION: One concrete recommendation. Menu of options = FAIL.\n\nOutput ONLY one of:\nOn FAIL: {\"status\": \"fail\", \"failure_reason\": \"Criterion N: reason\", \"context_updates\": {\"quality_feedback\": \"Fix these issues: ...\"}}\nOn SUCCESS: {\"status\": \"success\"}"
        ]
    }

    // Comment drafter — writes bridge.* output variables for the bridge to post.
    // Always runs as the final step before done, regardless of path taken.
    // Reads $triage_summary which is set by either manager (simple) or investigate (complex/HITL).
    comment_draft [
        label     = "Draft Comment",
        shape     = box,
        fillcolor = "#E8F0FE",
        prompt    = "The triage findings are in $triage_summary.\n\nWrite a triage analysis and output it as JSON with context_updates containing bridge output variables.\n\nStructure the comment as:\n- Lead with a 2-3 sentence plain-English summary of the root cause and recommended fix\n- If sibling modules were checked, show what was found\n- Give a single concrete recommendation, not options\n- Only report what was verified (from code if investigated, from issue context if triaged directly)\n\nYour entire response must be ONLY this JSON:\n{\"status\": \"success\", \"context_updates\": {\"bridge.comment\": \"YOUR TRIAGE COMMENT IN MARKDOWN\", \"bridge.status\": \"triaged\", \"bridge.summary\": \"ONE-LINE SUMMARY OF ROOT CAUSE AND FIX\", \"bridge.labels\": [\"bug\", \"triaged\"]}}\n\nDo NOT call any GitHub tools directly. The bridge reads these bridge.* variables and handles all GitHub I/O.\\n\\nCRITICAL: Your ENTIRE response must be ONLY the JSON object above. No preamble, no explanation, no markdown code fences, no text before or after. Just the raw JSON."
    ]

    // Pipeline exit
    done [
        label     = "Done",
        shape     = Msquare,
        fillcolor = "#FFCDD2"
    ]

    // ═══════════════════════════════════════════════════════════════════
    // EDGES
    // ═══════════════════════════════════════════════════════════════════

    start -> manager

    // SIMPLE: manager can triage directly — skip investigation.
    // Only fires when manager explicitly sets context.complexity=simple.
    manager -> comment_draft [
        label     = "simple",
        condition = "context.complexity=simple",
        color     = "#43A047",
        fontcolor = "#43A047"
    ]

    // COMPLEX: route to discover_repos for deep investigation.
    // Only fires when manager explicitly sets context.complexity=complex.
    manager -> discover_repos [
        label     = "complex",
        condition = "context.complexity=complex",
        color     = "#1565C0",
        fontcolor = "#1565C0"
    ]

    // FALLBACK: refine_question is the safe default for ambiguous issues.
    // Unconditional — catches explicit "needs_clarification" routing AND
    // cases where the LLM output wasn't parsed as structured JSON.
    // Asking for clarification is always safer than diving into code.
    manager -> refine_question [
        label = "clarify (fallback)"
    ]

    // ── Clarification loop edges ──────────────────────────────────────

    refine_question -> ask_human

    ask_human -> process_answer

    process_answer -> check_clarify_done

    // MORE QUESTIONS: loop back to refine_question for another round
    check_clarify_done -> refine_question [
        label     = "more questions",
        condition = "context.tool.output=more_questions",
        style     = dashed,
        color     = "#FF9800",
        fontcolor = "#FF9800"
    ]

    // DONE CLARIFYING: proceed to investigation
    check_clarify_done -> discover_repos [
        label     = "done clarifying",
        condition = "context.tool.output=done",
        color     = "#43A047",
        fontcolor = "#43A047"
    ]

    // ── Investigation edges ───────────────────────────────────────────

    discover_repos -> investigate

    investigate -> quality_eval [
        thread_id = "quality-thread",
        fidelity  = "compact"
    ]

    // SUCCESS: quality approved — move to comment drafting
    quality_eval -> comment_draft [
        label     = "outcome=success",
        condition = "outcome=success",
        color     = "#43A047",
        fontcolor = "#43A047"
    ]

    // FAIL: quality rejected — investigator retries with critique
    quality_eval -> investigate [
        label     = "outcome!=success",
        condition = "outcome!=success",
        style     = dashed,
        color     = "#E57373",
        fontcolor = "#E57373"
    ]

    comment_draft -> done

}
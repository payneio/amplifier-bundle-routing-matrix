// resolve-router.dot
//
// Pipeline: Resolve Router — dispatches to triage, implement, review, or answer sub-pipelines
//
// Flow:
//   1. Router LLM reads $goal (includes issue body + full comment thread)
//   2. Router outputs JSON with context_updates containing the route
//   3. Edge conditions on context.route dispatch to the right leg
//
// The router uses JSON output so the route lands in context_updates
// (the dot-graph resolver does NOT write response.md files).

digraph resolve_router {

    // — Graph-level attributes ————————————————————————————————————————

    label       = "Resolve Router"
    description = "Route incoming requests to the appropriate sub-pipeline based on intent analysis"
    goal        = "$goal"
    rankdir     = TB

    // — Default node and edge styles ————————————————————————————

    node [fontname="Helvetica", fontsize=11, style="filled"]
    edge [fontname="Helvetica", fontsize=10, color="#555555"]

    // ═══════════════════════════════════════════════════════════════════
    // PIPELINE NODES
    // ═══════════════════════════════════════════════════════════════════

    // Entry point
    start [
        label     = "Start",
        shape     = Mdiamond,
        fillcolor = "#C8E6C9"
    ]

    // Router — LLM reads the goal (which includes the issue body and
    // the full comment thread) and outputs a JSON routing decision.
    // The route is stored as context.route for edge conditions.
    router [
        label     = "Router",
        shape     = box,
        fillcolor = "#E8F0FE",
        prompt    = "You are a routing agent. Read the request and conversation in $goal.\n\nDecide which pipeline should handle this request:\n- triage: Investigate, analyze, or categorize an issue to understand what's wrong\n- implement: Propose a change to the code in this repository — fix a bug, add a feature, or make an improvement and open a PR\n- review: Review an existing pull request for code quality, correctness, and test coverage\n- answer: Answer a question, provide information, or respond to a follow-up that doesn't require code changes or investigation\n\nConsider the FULL conversation thread in $goal — not just the latest message. Previous comments provide important context about what has already been done.\n\nOutput ONLY this JSON (no preamble, no code fences):\n{\"status\": \"success\", \"context_updates\": {\"route\": \"CHOSEN_ROUTE\"}}\n\nReplace CHOSEN_ROUTE with exactly one of: triage, implement, review, answer"
    ]

    // Triage sub-pipeline
    triage_leg [
        label     = "Triage",
        shape     = folder,
        fillcolor = "#C8E6C9",
        dot_file  = ".amplifier-resolve/triage-dynamic.dot",
        outputs   = "bridge.comment,bridge.summary,bridge.labels"
    ]

    // Implement sub-pipeline
    implement_leg [
        label     = "Implement",
        shape     = folder,
        fillcolor = "#BBDEFB",
        dot_file  = ".amplifier-resolve/implement.dot",
        outputs   = "bridge.comment,bridge.summary,bridge.labels,delivery.pr_url"
    ]

    // Review sub-pipeline
    review_leg [
        label     = "Review",
        shape     = folder,
        fillcolor = "#F8BBD0",
        dot_file  = ".amplifier-resolve/review.dot",
        outputs   = "bridge.comment,bridge.summary,bridge.labels"
    ]

    // Answer — a simple LLM node that responds directly without
    // a sub-pipeline. For questions, follow-ups, or requests that
    // don't need investigation or code changes.
    answer_leg [
        label     = "Answer",
        shape     = box,
        fillcolor = "#FFF3E0",
        prompt    = "Read the conversation in $goal. The user is asking a question or making a follow-up request that doesn't require code investigation or changes.\n\nProvide a helpful, direct answer based on the conversation context and any prior triage/implement results visible in the thread.\n\nOutput:\n{\"status\": \"success\", \"context_updates\": {\"bridge.comment\": \"YOUR ANSWER IN MARKDOWN\", \"bridge.summary\": \"ONE-LINE SUMMARY\", \"bridge.labels\": [\"answered\"]}}\n\nCRITICAL: Your ENTIRE response must be ONLY the JSON object. No preamble, no explanation, no code fences."
    ]

    // Pipeline exit
    done [
        label     = "Done",
        shape     = Msquare,
        fillcolor = "#FFCDD2"
    ]

    // ═══════════════════════════════════════════════════════════════════
    // EDGES
    // ═══════════════════════════════════════════════════════════════════

    start -> router

    // Route based on context.route set by the router's JSON output
    router -> triage_leg [
        label     = "triage",
        condition = "context.route=triage",
        color     = "#43A047",
        fontcolor = "#43A047",
        weight    = 2
    ]

    router -> implement_leg [
        label     = "implement",
        condition = "context.route=implement",
        color     = "#1565C0",
        fontcolor = "#1565C0",
        weight    = 2
    ]

    router -> review_leg [
        label     = "review",
        condition = "context.route=review",
        color     = "#AD1457",
        fontcolor = "#AD1457",
        weight    = 2
    ]

    router -> answer_leg [
        label     = "answer",
        condition = "context.route=answer",
        color     = "#E65100",
        fontcolor = "#E65100",
        weight    = 2
    ]

    // Unconditional fallback — default to triage
    router -> triage_leg [
        label  = "fallback",
        style  = dashed,
        color  = "#999999"
    ]

    // All legs lead to done
    triage_leg -> done
    implement_leg -> done
    review_leg -> done
    answer_leg -> done

}
